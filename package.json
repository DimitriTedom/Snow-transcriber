{
  "name": "snow-transcriber",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "node scripts/run-next.mjs dev",
    "build": "node scripts/run-next.mjs build",
    "vercel-build": "node scripts/run-prisma.mjs generate && node scripts/run-next.mjs build",
    "start": "node scripts/run-next.mjs start",
    "lint": "node scripts/run-next.mjs lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "node scripts/run-prisma.mjs generate",
    "db:generate": "node scripts/run-prisma.mjs generate",
    "db:migrate": "node scripts/run-prisma.mjs migrate dev",
    "db:migrate:deploy": "node scripts/run-prisma.mjs migrate deploy",
    "db:studio": "node scripts/run-prisma.mjs studio",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "engine:up": "docker compose up engine --build -d",
    "engine:down": "docker compose stop engine",
    "engine:logs": "docker compose logs -f engine",
    "dev:all": "node scripts/dev-all.mjs",
    "mcp:install": "npm install --prefix mcp-server",
    "mcp:build": "npm run build --prefix mcp-server",
    "mcp:dev": "npm run dev --prefix mcp-server"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/ssr": "^0.12.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-toastify": "^11.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "wavesurfer.js": "^7.12.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.4",
    "eslint": "^10",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^7"
  }
}
